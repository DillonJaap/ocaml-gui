(version 1)

(build
 (choice
  ((((arch x86_64)
     (os linux))
    ((arch arm64)
     (os linux)))
   ((action
     (run pkg-config xi))))))

(depends
 (choice
  ((((arch x86_64)
     (os linux))
    ((arch arm64)
     (os linux)))
   (conf-pkg-config))))

(depexts
 ((libxi-dev)
  (or_absorb_undefined_var
   (= %{os_family} debian)
   (= %{os_family} ubuntu)))
 ((libXi-devel)
  (or_absorb_undefined_var
   (= %{os_family} fedora)
   (= %{os_family} rhel)
   (= %{os_family} suse)
   (= %{os_family} opensuse)))
 ((libxi-dev)
  (= %{os_distribution} alpine))
 ((libxi)
  (= %{os_distribution} arch))
 ((libXi)
  (= %{os_distribution} freebsd))
 ((libxi)
  (and_absorb_undefined_var
   (= %{os} macos)
   (= %{os_distribution} homebrew))))

(enabled_on_platforms
 (only
  ((arch x86_64)
   (os linux))
  ((arch arm64)
   (os linux))))
