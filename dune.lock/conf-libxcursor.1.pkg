(version 1)

(build
 (choice
  ((((arch x86_64)
     (os linux))
    ((arch arm64)
     (os linux)))
   ((action
     (run pkg-config xcursor))))))

(depends
 (choice
  ((((arch x86_64)
     (os linux))
    ((arch arm64)
     (os linux)))
   (conf-pkg-config))))

(depexts
 ((libxcursor-dev)
  (or_absorb_undefined_var
   (= %{os_family} debian)
   (= %{os_family} ubuntu)))
 ((libXcursor-devel)
  (or_absorb_undefined_var
   (= %{os_family} fedora)
   (= %{os_family} rhel)
   (= %{os_family} suse)
   (= %{os_family} opensuse)))
 ((libxcursor-dev)
  (= %{os_distribution} alpine))
 ((libxcursor)
  (= %{os_distribution} arch))
 ((libXcursor)
  (= %{os_distribution} freebsd))
 ((libxcursor)
  (and_absorb_undefined_var
   (= %{os} macos)
   (= %{os_distribution} homebrew))))

(enabled_on_platforms
 (only
  ((arch x86_64)
   (os linux))
  ((arch arm64)
   (os linux))))
